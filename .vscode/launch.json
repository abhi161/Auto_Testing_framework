{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Playwright Agent Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode-extension",
        "--new-window",
        "${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/vscode-extension/dist/**/*.js"],
      "preLaunchTask": "watch-extension"
    }
  ]
}
