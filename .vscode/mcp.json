{
  "servers": {
    "playwright-test": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "figma": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "figma-developer-mcp", "--stdio"],
      "env": {
        "FIGMA_TOKEN": "${env:FIGMA_TOKEN}"
      }
    }
  }
}
